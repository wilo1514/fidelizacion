NODE_ENV=production
PORT=3000
APP_BASE_URL=https://clientes.megatiendadelsur.com.ec
PUBLIC_BASE_URL=https://clientes.megatiendadelsur.com.ec
TZ=America/Guayaquil

APP_SQLSERVER_HOST=127.0.0.1
APP_SQLSERVER_PORT=1433
APP_SQLSERVER_DATABASE=Fidelizacion
APP_SQLSERVER_USER=fidelizacion_app
APP_SQLSERVER_PASSWORD=CAMBIAR_PASSWORD
APP_SQLSERVER_ENCRYPT=false

ICG_SQLSERVER_HOST=127.0.0.1
ICG_SQLSERVER_PORT=1433
ICG_SQLSERVER_DATABASE=ICG
ICG_SQLSERVER_USER=icg_user
ICG_SQLSERVER_PASSWORD=CAMBIAR_PASSWORD
ICG_SQLSERVER_ENCRYPT=false
ICG_CUSTOMER_QUERY=SELECT TOP 1 CodigoCliente, Nombre, Apellidos, Documento, Movil, Email FROM Clientes WHERE Documento = @document

SAP_SL_BASE_URL=https://sapserver:50000/b1s/v2
SAP_SL_COMPANY_DB=SBODEMOEC
SAP_SL_USERNAME=manager
SAP_SL_PASSWORD=CAMBIAR_PASSWORD

SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@megatiendadelsur.com.ec
SMTP_PASSWORD=CAMBIAR_PASSWORD
SMTP_FROM_NAME=Mega Tienda del Sur
SMTP_FROM_EMAIL=no-reply@megatiendadelsur.com.ec

ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASSWORD=CAMBIAR_PASSWORD_FUERTE
ADMIN_SESSION_SECRET=CAMBIAR_SECRETO_LARGO
CONSENT_TOKEN_TTL_HOURS=24
QR_SESSION_TTL_MINUTES=15
